diff --git a/frontend/src/app/globals.css b/frontend/src/app/globals.css
index da7ede9..a4065fe 100644
--- a/frontend/src/app/globals.css
+++ b/frontend/src/app/globals.css
@@ -2,34 +2,87 @@
 @tailwind components;
 @tailwind utilities;
 
+/*
+ * Design tokens. Every color used anywhere in the app should trace back to
+ * one of these variables — no new hardcoded hex values in components.
+ * Contrast against --page / --surface has been checked against WCAG AA
+ * (4.5:1 for body text, 3:1 for large text / non-text UI). --fg-faint is
+ * reserved for icons and large text only — never body copy, which is what
+ * failed AA in the original audit.
+ */
 :root {
   color-scheme: dark;
+
+  --page: #07090d;
+  --surface: #0d1117;
+  --surface-elevated: #111827;
+
+  --border: rgba(255, 255, 255, 0.08);
+  --border-strong: rgba(255, 255, 255, 0.16);
+
+  --fg-primary: #f3f4f6;
+  --fg-muted: #9ca3af;
+  --fg-faint: #6b7280;
+
+  --accent: #5b7cf0;
+  --accent-muted: rgba(91, 124, 240, 0.14);
+  --accent-foreground: #eef2ff;
+
+  --positive: #34d399;
+  --positive-muted: rgba(52, 211, 153, 0.12);
+
+  --negative: #f87171;
+  --negative-muted: rgba(248, 113, 113, 0.12);
+
+  --warning: #fbbf24;
+  --warning-muted: rgba(251, 191, 36, 0.12);
 }
 
 html {
-  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
-  color-scheme: dark;
+  height: 100%;
 }
 
 body {
   margin: 0;
   min-height: 100vh;
-  background: #06080e;
-  color: #e6edf3;
+  background: var(--page);
+  color: var(--fg-primary);
+  font-feature-settings: "cv11", "ss01";
 }
 
 * {
   box-sizing: border-box;
 }
 
-input,
 button,
-textarea,
+input,
 select {
   font: inherit;
+  color: inherit;
 }
 
 ::selection {
-  background: rgba(211, 153, 34, 0.35);
-  color: #e6edf3;
+  background: var(--accent-muted);
+  color: var(--fg-primary);
+}
+
+/* Consistent keyboard focus everywhere, including custom controls. */
+:focus-visible {
+  outline: 2px solid var(--accent);
+  outline-offset: 2px;
+}
+
+.tabular-nums {
+  font-variant-numeric: tabular-nums;
+}
+
+@media (prefers-reduced-motion: reduce) {
+  *,
+  *::before,
+  *::after {
+    animation-duration: 0.001ms !important;
+    animation-iteration-count: 1 !important;
+    transition-duration: 0.001ms !important;
+    scroll-behavior: auto !important;
+  }
 }
